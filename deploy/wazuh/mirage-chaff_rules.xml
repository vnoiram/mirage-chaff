<!--
  Wazuh rules for mirage-chaff (design doc §9). Install into
  /var/ossec/etc/rules/ on the Wazuh manager. mirage-chaff is a MITM control
  plane, so admin/CA/config/kill-switch events are high value.
-->
<group name="mirage-chaff,">

  <rule id="120500" level="3">
    <decoded_as>mirage-chaff-audit</decoded_as>
    <field name="action">\.+</field>
    <description>mirage-chaff audit: $(action) by $(actor)</description>
  </rule>

  <rule id="120501" level="5">
    <if_sid>120500</if_sid>
    <field name="action">^login.fail$</field>
    <description>mirage-chaff admin login failure for $(actor)</description>
    <group>authentication_failed,</group>
  </rule>

  <rule id="120502" level="10" frequency="5" timeframe="120">
    <if_matched_sid>120501</if_matched_sid>
    <same_field>actor</same_field>
    <description>mirage-chaff: repeated admin login failures for $(actor) (possible brute force)</description>
    <group>authentication_failures,</group>
  </rule>

  <rule id="120510" level="12">
    <if_sid>120500</if_sid>
    <field name="action">^killswitch.execute$</field>
    <description>mirage-chaff KILL-SWITCH executed by $(actor)</description>
  </rule>

  <rule id="120511" level="10">
    <if_sid>120500</if_sid>
    <field name="action">^config.edit$</field>
    <description>mirage-chaff config edited by $(actor)</description>
  </rule>

  <rule id="120512" level="10">
    <if_sid>120500</if_sid>
    <field name="action">^users.(create|delete|setpassword)$</field>
    <description>mirage-chaff user management ($(action)) by $(actor)</description>
  </rule>

  <rule id="120513" level="8">
    <if_sid>120500</if_sid>
    <field name="action">^policy.edit$</field>
    <description>mirage-chaff policy edited by $(actor): $(detail)</description>
  </rule>

</group>
