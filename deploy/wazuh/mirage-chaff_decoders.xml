<!--
  Wazuh decoders for mirage-chaff security audit events (design doc §9).
  Install into /var/ossec/etc/decoders/ on the Wazuh manager (roles/wazuh_server).

  mirage-chaff emits, via journald/syslog, lines like:
    SECURITY mirage-chaff-audit {"time":"...","actor":"admin","action":"login.fail","detail":"invalid credentials"}
-->
<decoder name="mirage-chaff-audit">
  <prematch>SECURITY mirage-chaff-audit </prematch>
</decoder>

<decoder name="mirage-chaff-audit-json">
  <parent>mirage-chaff-audit</parent>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>

<!-- Request logs include catalog fields when available:
     req {"catalog_id":"...","category":"ad_sdk","risk":"high","verified":false,
          "review_status":"candidate","rewrite_state":"...","cname_target":"..."} -->
<decoder name="mirage-chaff-request">
  <prematch>req \{</prematch>
</decoder>

<decoder name="mirage-chaff-request-json">
  <parent>mirage-chaff-request</parent>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>
