{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "title": "mirage-chaff",
  "uid": "mirage-chaff",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Up",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [ { "expr": "mirage_chaff_up", "refId": "A" } ],
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } } ] } }
    },
    {
      "type": "stat",
      "title": "Policy rules",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [ { "expr": "mirage_chaff_policy_rules", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Unmatched (curation candidates)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 8, "y": 0 },
      "targets": [ { "expr": "mirage_chaff_unmatched_domains", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "CA expires in",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 5, "x": 13, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [ { "expr": "mirage_chaff_intermediate_ca_not_after_seconds - time()", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Requests by action (rate)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [ { "expr": "sum by (action) (rate(mirage_chaff_requests_total[5m]))", "legendFormat": "{{action}}", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Responses by class (rate)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [ { "expr": "sum by (class) (rate(mirage_chaff_responses_total[5m]))", "legendFormat": "{{class}}", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Response bytes (rate)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [ { "expr": "rate(mirage_chaff_response_bytes_total[5m])", "legendFormat": "bytes/s", "refId": "A" } ]
    },
    {
      "type": "logs",
      "title": "Recent requests (Loki)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [ { "expr": "{job=\"mirage-chaff\"} |= \"req \"", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Catalog classifications (rate)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum by (category,risk,verified,review_status,source_type) (rate(mirage_chaff_catalog_requests_total[5m]))",
          "legendFormat": "{{category}} {{risk}} verified={{verified}} {{review_status}} {{source_type}}",
          "refId": "A"
        }
      ]
    }
  ]
}
