# mirage-chaff.conf (sample) — TOML
#
# Copy to /etc/mirage-chaff/mirage-chaff.conf and edit. Validate with:
#   mirage-chaff check -config /etc/mirage-chaff/mirage-chaff.conf
#
# Reload semantics: fields tagged "reload-safe" below apply on `systemctl reload`
# (SIGHUP). Fields tagged "restart" require `systemctl restart` (socket rebind).

version = 1

# Data-path intercept listeners (restart).
[listen]
http  = ":80"
https = ":443"
ipv6  = true      # dual-stack; also rewrite AAAA in AGH to close the IPv6 bypass

# Transport / application protocols (restart — sockets/ALPN).
# Default: QUIC OFF. On constrained VMs block UDP443 at the firewall and let
# clients fall back to TCP (see deploy/firewall-udp443.sh). Enable as opt-in.
[protocols]
http1 = true
http2 = true
quic  = false
http3 = false     # requires quic = true

# Intermediate CA + dynamic leaf issuance.
# SECURITY: the intermediate CA MUST carry Name Constraints limiting issuance to
# the curated domains (see deploy/gen-ca.sh). key_type ecdsa is lighter for VMs.
[cert]
intermediate_cert = "/etc/mirage-chaff/ca/intermediate.crt"
intermediate_key  = "/etc/mirage-chaff/ca/intermediate.key"
key_type          = "ecdsa"     # "ecdsa" (default) | "rsa"  (restart)
cache_max         = 2048        # reload-safe
cache_ttl_hours   = 168         # reload-safe
cache_dir         = "/var/lib/mirage-chaff/certcache"

# INDEPENDENT resolver for forward/passthrough real-IP resolution.
# MUST NOT be AdGuard Home, or you create a DNS rewrite loop.
[upstream]
resolvers = ["https://1.1.1.1/dns-query", "https://9.9.9.9/dns-query"]

# Global mode: "full" (all actions) | "stub-only" (lightest: decoys only).
mode = "full"                   # reload-safe (stub side)

# forward-mimic (shape-preserving decoys). Phase 4 scope: image/js/binary.
[mimic]
enabled     = true              # reload-safe
max_bytes   = 8388608           # 8 MiB; over this -> stub fallback
cache_max   = 512
allow_video = false             # video -> stub/asis (design decision C-1)

# Resource caps for constrained VMs (pair with systemd MemoryMax/CPUQuota).
[resources]
max_conns      = 1024           # reload-safe
rate_limit     = 0              # 0 = unlimited; reload-safe
body_max_bytes = 33554432       # 32 MiB; reload-safe

# Structured logging + redaction (reload-safe).
[log]
level  = "info"                 # debug|info|warn|error
mode   = "redacted"             # off|redacted|stats|debug|full
retention = "7d"
redact = true                   # mask URL/query/header sensitive values BEFORE Loki

[[log.debug_scope]]
domain = ""
client = ""
ttl    = "1h"

# Health/metrics — INDEPENDENT of the admin UI so watchdog/monitoring survive
# admin.enabled = false. Serves /-/healthy, /ready, and /metrics.
[observability]
listen  = "127.0.0.1:9256"      # restart
metrics = true                  # restart (toggles /metrics only)

[observability.catalog]
enabled = true                  # low-cardinality catalog/risk/review metrics only
prometheus_labels = ["category", "risk", "verified", "review_status", "source_type"]
emit_siem_catalog_fields = true

# AdGuard Home metadata sync. AGH remains the DNS enforcement point; mirage only
# mirrors rule metadata for triage, unknown fallback, analytics, and review.
[agh_sync]
enabled = false
base_url = "http://127.0.0.1:3000"
env_file = "/etc/mirage-chaff/agh.env"
sync_interval = "1h"
sync_filters = true
sync_custom_rules = true
sync_allow_deny = true
sync_query_log = false
# filter_urls = ["https://example.invalid/easyprivacy.txt"]
# custom_rules = ["||ads.example.net/sdk.js$script", "0.0.0.0 tracker.example.net"]

[agh_sync.cname]
enabled = true
use_query_log = true
known_tracker_sources = ["rule_catalog"]
candidate_min_confidence = "medium"

[rule_catalog]
path = "/var/lib/mirage-chaff/rule-catalog.json"
refresh_on_reload = true

[unknown_profile]
enabled = true
default = "safe"                # safe|balanced|aggressive

[unknown_profile.safe]
suspicious_domain = "observe"
tracking_pixel = "forward"
beacon = "forward"
javascript = "forward"
api_json = "forward"

[unknown_profile.balanced]
suspicious_domain = "observe"
tracking_pixel = "stub:pixel"
beacon = "stub:beacon-204"
javascript = "forward"
api_json = "forward"

[unknown_profile.aggressive]
suspicious_domain = "stub:beacon-204"
tracking_pixel = "stub:pixel"
beacon = "stub:beacon-204"
javascript = "candidate-log"
api_json = "forward"

# Web admin UI (MITM control plane). Localhost + auth by default; off = lightest.
[admin]
enabled = false                 # restart
listen  = "127.0.0.1:8443"      # restart

# Optional OIDC SSO for the admin UI (maps OIDC groups -> RBAC roles). Local
# accounts remain a fallback. Leave enabled=false to use local accounts only.
[admin.oidc]
enabled       = false
issuer        = "https://idp.example.com/realms/example"
client_id     = "mirage-chaff"
client_secret = ""              # keep out of git; inject via deploy/vault
redirect_url  = "https://cushion.example.com:8443/api/oidc/callback"
groups_claim  = "groups"
[admin.oidc.role_map]
# "sso-admins" = "admin"
# "sso-editors"    = "editor"
# "sso-viewers" = "viewer"

# On-disk paths.
[paths]
policy_dir  = "/etc/mirage-chaff/policy.d"   # reload-safe
catalog_dir = "/etc/mirage-chaff/catalog"    # reload-safe
state_dir   = "/var/lib/mirage-chaff"
agh_env     = "/etc/mirage-chaff/agh.env"    # kill-switch AGH creds (0600, git-ignored)
